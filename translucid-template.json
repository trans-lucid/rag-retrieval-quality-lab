{
  "schema_version": "1.0",
  "template_id": "template002",
  "template_slug": "rag-retrieval-quality-lab",
  "title": "RAG Retrieval Quality Lab",
  "render_command": "make render",
  "scan_command": "make scan-safety",
  "validate_solution_command": "make validate-solution",
  "validate_expected_failure_command": "make validate-candidate-main-expected-failure",
  "validate_docker_command": "make validate-docker-integration",
  "validate_all_command": "make validate",
  "generated_candidate_dir": "generated/main",
  "generated_solution_dir": "generated/solution",
  "template_context_file": "template_context.json",
  "requires_docker_compose": true,
  "expected_failure_markers": [
    "tenant_leak_detected",
    "stale_doc_ranked_first",
    "missing_grounded_citation"
  ],
  "candidate_public_commands": [
    "make test-unit"
  ],
  "candidate_docker_commands": [
    "make dev",
    "make seed",
    "make index",
    "make test-integration",
    "make clean"
  ],
  "forbid_manual_restructure": true,
  "candidate_main_forbidden_paths": [
    "solution/",
    "evaluator/",
    "tests_hidden/",
    "fixtures_hidden/",
    "SOLUTION.md",
    "SOLUTION.md.j2",
    "rubric.md",
    "source-dossiers/",
    "template.yaml",
    "metadata/"
  ],
  "validate_personalization_command": "make validate-personalization",
  "check_published_repo_command": "make check-published-repo",
  "personalization_contract": {
    "difficulty_levels": [
      "junior",
      "senior",
      "staff"
    ],
    "allowed_focus_axes": [
      "tenant isolation",
      "ACL filtering",
      "retrieval relevance",
      "freshness handling",
      "citation grounding",
      "eval/report quality"
    ],
    "scenario_knobs": {
      "entity_count": [
        "low",
        "medium",
        "high"
      ],
      "failure_modes": [
        "basic",
        "multi_step",
        "ambiguous"
      ],
      "hidden_strictness": [
        "basic",
        "production",
        "adversarial"
      ],
      "reporting_depth": [
        "short",
        "operator",
        "executive_plus_operator"
      ]
    },
    "generator_commands": [
      "python3 generators/generate_fixture.py --profile template_context.json --out candidate/fixtures/public/generated_personalization_documents.jsonl"
    ],
    "candidate_forbidden_markers": [
      "## Personalized Context",
      "source_profile",
      "source_profile_summary",
      "SOLUTION.md",
      "source-dossiers",
      "private evaluator material",
      "hidden_test_emphasis"
    ],
    "solution_cue_requirements": [
      "focus being evaluated",
      "expected failure classes",
      "hidden test intent",
      "scoring rubric",
      "debrief answer cues"
    ]
  }
}
